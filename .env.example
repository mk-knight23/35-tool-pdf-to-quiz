# QuizFlow AI — Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================

# OpenRouter API Key for AI quiz generation
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Default AI model (see OpenRouter for available models)
VITE_DEFAULT_MODEL=google/gemini-flash-1.5-8b:free

# ===========================================
# Backend Server (Optional)
# ===========================================

# Backend API URL for quiz backup/restore functionality
VITE_API_URL=http://localhost:3001

# ===========================================
# Development Settings
# ===========================================

# Enable debug logging
VITE_DEBUG_MODE=false

# Analytics enabled (requires backend)
VITE_ANALYTICS_ENABLED=false
