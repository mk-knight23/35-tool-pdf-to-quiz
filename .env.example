# MK QuizFlow — environment variables
# Copy to `.env.local` and fill in as needed. Every variable is OPTIONAL:
# the app builds and the deterministic Quick mode works with none of them set.
# NEVER commit `.env.local` (git-ignored). Only this example file is tracked.

# ----------------------------------------------------------------------------
# AI layer (optional)  — see AI_ARCHITECTURE.md
# ----------------------------------------------------------------------------
# AI features route through the Vercel AI Gateway using gateway model strings.
# Provide server credentials with EITHER of the following:
#
#   1. AI_GATEWAY_API_KEY — a Vercel AI Gateway key (starts with "vck_").
#      Use this for local development or non-Vercel hosting.
#
#   2. VERCEL_OIDC_TOKEN — injected automatically by `vercel dev` and by Vercel
#      at deploy time. You normally do NOT set this by hand; run `vercel env pull`
#      to populate it locally. Do not commit it.
#
# When neither is set, AI mode degrades honestly to an "AI unavailable" message
# and the deterministic Quick mode (no AI) keeps working. Users can also supply
# their own key (BYOK) at runtime from Settings — that key is held only in the
# browser tab's session memory and sent per-request as the `x-byok-key` header;
# it is never logged or stored server-side.
AI_GATEWAY_API_KEY=
# VERCEL_OIDC_TOKEN is managed by Vercel — leave unset locally unless pulled.

# Model selection (gateway model strings). Defaults are used when unset, so a
# model change is a one-line env fix with no code change.
# Fast tier default:    anthropic/claude-haiku-4.5
# Quality tier default: anthropic/claude-sonnet-4-5
AI_MODEL=
AI_MODEL_QUALITY=

# ----------------------------------------------------------------------------
# SEO / canonical (optional)
# ----------------------------------------------------------------------------
# Drives canonical URLs, Open Graph, and the sitemap. Defaults to the product's
# target domain (https://quizflow.mkazi.live) when unset.
NEXT_PUBLIC_SITE_URL=https://quizflow.mkazi.live

# ----------------------------------------------------------------------------
# Analytics (optional, consent-gated, production-only)
# ----------------------------------------------------------------------------
# When unset, analytics are a no-op. Scripts only load in production AND after
# the user grants consent on the cookie banner. No document text, quiz content,
# file names, or keys are ever sent — only counts, durations, and feature names.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# ----------------------------------------------------------------------------
# Monetization (optional, disabled by default)  — see MONETIZATION_PLAN.md
# ----------------------------------------------------------------------------
# When no AdSense client ID is set, no ad script loads and the reserved ad slots
# render a non-tracking sponsor callout instead (no layout shift).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# Optional "buy me a coffee" / sponsor link shown in the fallback ad slot.
NEXT_PUBLIC_SPONSOR_URL=
